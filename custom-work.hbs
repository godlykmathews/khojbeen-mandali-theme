{{!< default}}

<main id="main-content" class="site-main">
  <div class="inner-container">
    {{#post}}
      <header
        class="page-header"
        style="text-align: center; margin-bottom: 4rem; padding-top: 2rem;"
      >
        <h1
          class="page-title"
          style="font-size: 3rem; margin-bottom: 0.5rem;"
        >{{title}}</h1>
        
        {{#if custom_excerpt}}
          <p
            class="page-description"
            style="font-size: 1.2rem; color: #666;"
          >{{custom_excerpt}}</p>
        {{/if}}
      </header>

      <div class="page-content" style="margin-bottom: 3rem;">
        {{content}}
      </div>
    {{/post}}

    <section
      class="work-section"
      style="margin: 0 auto 4rem auto; max-width: 1200px;"
    >
      {{#get "posts" filter="tag:work" limit="100"}}
        <div style="display: flex; flex-direction: column; gap: 2rem;">
        {{#foreach posts}}
          <article
            class="work-post"
            style="display: flex; gap: 4rem; align-items: center; padding: 3rem; flex-wrap: wrap; {{#if @even}}background-color: #e5ead3; flex-direction: row; text-align: right;{{else}}background-color: transparent; flex-direction: row-reverse; text-align: left;{{/if}}"
          >
            {{#if feature_image}}
              <div style="flex: 1; min-width: 300px;">
                <img
                  src="{{img_url feature_image size="l"}}"
                  alt="{{title}}"
                  style="width: 100%; height: auto; object-fit: cover; border: 2px solid #2b6142;"
                  loading="lazy"
                />
              </div>
            {{/if}}
            <div class="work-content" style="flex: 1; min-width: 300px; display: flex; flex-direction: column; justify-content: center; {{#if @even}}align-items: flex-end;{{else}}align-items: flex-start;{{/if}}">
              <h2 style="margin-top: 0; margin-bottom: 1rem; font-size: 2rem; color: #111;">{{title}}</h2>
              
              <div style="margin: 0 0 1.5rem 0; color: #444; font-size: 1.15rem; line-height: 1.6; display: -webkit-box; -webkit-line-clamp: 4; -webkit-box-orient: vertical; overflow: hidden;">
                {{content}}
              </div>
              
              <a href="{{url}}" style="display: inline-block; background-color: #31724a; color: white; padding: 0.6rem 1.5rem; border-radius: 25px; text-decoration: none; font-weight: 800; font-size: 0.9rem; letter-spacing: 0.5px; text-transform: uppercase; box-shadow: 0 4px 6px rgba(0,0,0,0.15);">READ MORE</a>
            </div>
          </article>
        {{/foreach}}
        </div>
      {{/get}}
    </section>
  </div>
</main>