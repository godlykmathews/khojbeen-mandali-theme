{{!< default}}

<main id="main-content" class="site-main">
  <div class="inner-container">
    {{#post}}
      <header
        class="page-header"
        style="text-align: center; margin-bottom: 4rem; padding-top: 2rem;"
      >
        <h1
          class="page-title"
          style="font-size: 3rem; margin-bottom: 0.5rem;"
        >{{title}}</h1>
        {{#if custom_excerpt}}
          <p
            class="page-description"
            style="font-size: 1.2rem; color: #666;"
          >{{custom_excerpt}}</p>
        {{/if}}
      </header>

      <div class="page-content" style="margin-bottom: 3rem;">
        {{content}}
      </div>
    {{/post}}

    <div class="post-feed">
      {{#get "posts" include="tags,authors" limit="all"}}
        {{#foreach posts}}
          <article
            class="post-card {{post_class}}"
            style="display: flex; gap: 1.5rem; align-items: flex-start; margin-bottom: 2rem; flex-wrap: wrap;"
          >
            {{#if feature_image}}
              <a
                class="post-card-image-link"
                href="{{url}}"
                style="flex: 0 0 250px; max-width: 100%;"
              >
                <img
                  class="post-card-image"
                  style="width: 100%; height: auto; object-fit: cover; border-radius: 8px; aspect-ratio: 16/9;"
                  srcset="{{img_url feature_image size="s"}} 300w,
                                        {{img_url feature_image size="m"}} 600w,
                                        {{img_url
                    feature_image
                    size="l"
                  }} 1000w"
                  sizes="(max-width: 1000px) 400px, 800px"
                  src="{{img_url feature_image size="m"}}"
                  alt="{{title}}"
                  loading="lazy"
                />
              </a>
            {{/if}}

            <div class="post-card-content" style="flex: 1; min-width: 250px;">
              <header class="post-card-header">
                {{#if primary_tag}}
                  <span
                    class="post-card-tags"
                    style="font-size: 0.85rem; text-transform: uppercase;"
                  >{{primary_tag.name}}</span>
                {{/if}}
                <h2
                  class="post-card-title"
                  style="margin-top: 0.25rem; font-size: 1.5rem;"
                ><a href="{{url}}">{{title}}</a></h2>
              </header>

              <div class="post-card-excerpt" style="margin-top: 0.5rem;">
                <p>{{excerpt words="33"}} <a href="{{url}}">read more...</a></p>
              </div>

              <footer class="post-card-meta">
                <time
                  class="post-card-meta-date"
                  datetime="{{date format="YYYY-MM-DD"}}"
                >{{date format="D MMM YYYY"}}</time>
                <span class="post-card-meta-length">
                  &bull;
                  {{reading_time}}</span>
              </footer>
            </div>
          </article>
        {{/foreach}}
      {{/get}}
    </div>
  </div>
</main>