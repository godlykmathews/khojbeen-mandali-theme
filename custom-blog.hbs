{{!< default}}

<main id="main-content" class="site-main blog-page">
  <div class="inner-container blog-inner">
    {{#post}}
      <header class="page-header blog-page-header">
        <h1 class="page-title blog-page-title">{{title}}</h1>
        {{#if custom_excerpt}}
          <p class="page-description blog-page-description">{{custom_excerpt}}</p>
        {{/if}}
      </header>

      <div class="page-content blog-page-content">
        {{content}}
      </div>
    {{/post}}

    <div class="post-feed blog-post-feed">
      {{#get "posts" filter="tag:blog" include="tags,authors" limit="100"}}
        {{#foreach posts}}
          <article class="post-card blog-post-card {{post_class}}">
            {{#if feature_image}}
              <a class="post-card-image-link blog-post-image-link" href="{{url}}">
                <img
                  class="post-card-image blog-post-image"
                  srcset="{{img_url feature_image size="s"}} 300w,
                          {{img_url feature_image size="m"}} 600w,
                          {{img_url feature_image size="l"}} 1000w"
                  sizes="(max-width: 1000px) 400px, 800px"
                  src="{{img_url feature_image size="m"}}"
                  alt="{{title}}"
                  loading="lazy"
                />
              </a>
            {{/if}}

            <div class="post-card-content blog-post-card-content">
              <header class="post-card-header">
                <h2 class="post-card-title blog-post-card-title"><a href="{{url}}">{{title}}</a></h2>
              </header>

              <div class="post-card-excerpt blog-post-card-excerpt hidden md:block">
                <p>{{excerpt words="33"}} <a href="{{url}}">read more...</a></p>
              </div>

              <footer class="post-card-meta">
                <time
                  class="post-card-meta-date"
                  datetime="{{date format="YYYY-MM-DD"}}"
                >{{date format="D MMM YYYY"}}</time>
                <span class="post-card-meta-length">
                  &bull;
                  {{reading_time}}</span>
              </footer>
            </div>
          </article>
        {{else}}
          <article class="blog-fallback-card">
            <h2 class="blog-fallback-title">Fresh stories are coming soon</h2>
            <p class="blog-fallback-copy">Our team is preparing new articles and reflections from the field. Please check back shortly.</p>
            <a href="/resources/" class="btn-learn-more">Explore Resources</a>
          </article>
        {{/foreach}}
      {{/get}}
    </div>

    {{! Newsletter Signup Section }}
    {{#if @site.members_enabled}}
      <section class="newsletter-signup">
        <div class="newsletter-content">
          <h2>Stay Updated</h2>
          <p>Subscribe to our newsletter and never miss a new post. Get the latest
            articles delivered straight to your inbox.</p>

          <form data-members-form="subscribe">
            <input
              type="email"
              name="email"
              placeholder="your@email.com"
              required
              data-members-email
            />
            <button type="submit">
              Subscribe
            </button>

            <div class="message-success">
              ✓ Great! Check your inbox for a confirmation email.
            </div>
            <div class="message-error">
              Something went wrong. Please try again.
            </div>
            <div class="message-loading">
              Subscribing...
            </div>
          </form>

          <p class="newsletter-note">No spam. Unsubscribe anytime.</p>
        </div>
      </section>
    {{/if}}
  </div>
</main>