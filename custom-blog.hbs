{{!< default}}

<main id="main-content" class="site-main">
  <div class="inner-container">
    {{#post}}
      <header
        class="page-header"
        style="text-align: center; margin-bottom: 4rem; padding-top: 2rem;"
      >
        <h1
          class="page-title"
          style="font-size: 3rem; margin-bottom: 0.5rem;"
        >{{title}}</h1>
        {{#if custom_excerpt}}
          <p
            class="page-description"
            style="font-size: 1.2rem; color: #666;"
          >{{custom_excerpt}}</p>
        {{/if}}
      </header>

      <div class="page-content" style="margin-bottom: 3rem;">
        {{content}}
      </div>
    {{/post}}

    <div class="post-feed">
      {{#get "posts" filter="tag:blog" include="tags,authors" limit="100"}}
        {{#foreach posts}}
          <article
            class="post-card {{post_class}}"
            style="display: flex; gap: 1.5rem; align-items: flex-start; margin-bottom: 2rem; flex-wrap: wrap;"
          >
            {{#if feature_image}}
              <a
                class="post-card-image-link"
                href="{{url}}"
                style="flex: 0 0 250px; max-width: 100%;"
              >
                <img
                  class="post-card-image"
                  style="width: 100%; height: auto; object-fit: cover; border-radius: 8px; aspect-ratio: 16/9;"
                  srcset="{{img_url feature_image size="s"}} 300w,
                          {{img_url feature_image size="m"}} 600w,
                          {{img_url feature_image size="l"}} 1000w"
                  sizes="(max-width: 1000px) 400px, 800px"
                  src="{{img_url feature_image size="m"}}"
                  alt="{{title}}"
                  loading="lazy"
                />
              </a>
            {{/if}}

            <div class="post-card-content" style="flex: 1; min-width: 250px;">
              <header class="post-card-header">
                <h2
                  class="post-card-title"
                  style="margin-top: 0.25rem; font-size: 1.5rem;"
                ><a href="{{url}}">{{title}}</a></h2>
              </header>

              <div class="post-card-excerpt" style="margin-top: 0.5rem;">
                <p>{{excerpt words="33"}} <a href="{{url}}">read more...</a></p>
              </div>

              <footer class="post-card-meta">
                <time
                  class="post-card-meta-date"
                  datetime="{{date format="YYYY-MM-DD"}}"
                >{{date format="D MMM YYYY"}}</time>
                <span class="post-card-meta-length">
                  &bull;
                  {{reading_time}}</span>
              </footer>
            </div>
          </article>
        {{/foreach}}
      {{/get}}
    </div>

    {{! Newsletter Signup Section }}
    {{#if @site.members_enabled}}
      <section
        class="newsletter-signup"
        style="margin-top: 4rem; padding: 3rem 2rem; background: linear-gradient(135deg, #f5f7fa 0%, #e4e8ec 100%); border-radius: 12px; text-align: center;"
      >
        <div
          class="newsletter-content"
          style="max-width: 500px; margin: 0 auto;"
        >
          <h2
            style="font-size: 1.75rem; margin-bottom: 0.75rem; color: #1a1a1a;"
          >Stay Updated</h2>
          <p
            style="color: #666; margin-bottom: 1.5rem; font-size: 1.1rem;"
          >Subscribe to our newsletter and never miss a new post. Get the latest
            articles delivered straight to your inbox.</p>

          <form
            data-members-form="subscribe"
            style="display: flex; flex-direction: column; gap: 1rem; align-items: center;"
          >
            <input
              type="email"
              name="email"
              placeholder="your@email.com"
              required
              data-members-email
              style="width: 100%; max-width: 350px; padding: 0.875rem 1rem; border: 2px solid #ddd; border-radius: 8px; font-size: 1rem; transition: border-color 0.2s ease;"
            />
            <button
              type="submit"
              style="padding: 0.875rem 2rem; background: #1a1a1a; color: white; border: none; border-radius: 8px; font-size: 1rem; font-weight: 600; cursor: pointer; transition: background 0.2s ease;"
            >
              Subscribe
            </button>

            <div
              class="message-success"
              style="display: none; color: #15803d; font-weight: 500;"
            >
              ✓ Great! Check your inbox for a confirmation email.
            </div>
            <div
              class="message-error"
              style="display: none; color: #dc2626; font-weight: 500;"
            >
              Something went wrong. Please try again.
            </div>
            <div class="message-loading" style="display: none; color: #666;">
              Subscribing...
            </div>
          </form>

          <p style="margin-top: 1rem; font-size: 0.85rem; color: #888;">No spam.
            Unsubscribe anytime.</p>
        </div>
      </section>
    {{/if}}
  </div>
</main>