{{!< default}}

{{#post}}
  <main id="main-content" class="site-main about-page">
    <div class="inner-container about-main-container">
      <article class="post-single about-page-article {{post_class}}">
        <header class="post-single-header about-page-header">
          {{#if feature_image}}
            <div class="about-feature-image-wrap">
              <img
                src="{{img_url feature_image size="l"}}"
                alt="{{title}}"
                class="about-feature-image"
                loading="lazy"
              />
            </div>
          {{/if}}

          {{#if custom_excerpt}}
            <p class="post-single-excerpt about-intro">{{custom_excerpt}}</p>
          {{/if}}
        </header>

        <div class="post-single-content gh-content about-content">
          {{content}}
        </div>
      </article>
    </div>

    <div class="inner-container team-container about-team-container">
      <section class="strategic-team-section team-section">
        <h2 class="team-section-title">Strategic Team</h2>
        {{#get "posts" filter="tag:hash-strategic-team" limit="100"}}
          <div class="team-grid strategic-team-grid">
            {{#foreach posts}}
              <article class="team-card strategic-team-card">
                {{#if feature_image}}
                  <img
                    src="{{img_url feature_image size="m"}}"
                    alt="{{title}}"
                    class="team-member-image"
                    loading="lazy"
                  />
                {{/if}}
                <h3 class="team-member-name">{{title}}</h3>
                {{#if custom_excerpt}}
                  <p class="tagline team-member-tagline">{{custom_excerpt}}</p>
                {{/if}}
                <div class="team-content">
                  {{content}}
                </div>
              </article>
            {{else}}
              <p class="section-empty-note">Strategic team profiles will appear here soon.</p>
            {{/foreach}}
          </div>
        {{/get}}
      </section>

      <section class="advisory-board-section team-section">
        <h2 class="team-section-title">Advisory Board</h2>
        {{#get "posts" filter="tag:hash-advisory-board" limit="100"}}
          <div class="advisory-grid">
            {{#foreach posts}}
              {{#if feature_image}}
                <article class="advisory-card">
                  <img
                    src="{{img_url feature_image size="s"}}"
                    alt="{{title}}"
                    class="advisory-member-image"
                    loading="lazy"
                  />
                  <h3 class="advisory-member-name">{{title}}</h3>
                  {{#if custom_excerpt}}
                    <p class="advisory-member-role">{{custom_excerpt}}</p>
                  {{/if}}
                </article>
              {{else}}
                <article class="advisory-list-item">
                  <h3 class="advisory-member-name">{{title}}</h3>
                  {{#if custom_excerpt}}
                    <p class="advisory-member-role advisory-member-role-inline">{{custom_excerpt}}</p>
                  {{/if}}
                </article>
              {{/if}}
            {{else}}
              <p class="section-empty-note">Advisory board profiles will appear here soon.</p>
            {{/foreach}}
          </div>
        {{/get}}
      </section>
    </div>
  </main>
{{/post}}