{{!< default}}

<main id="main-content" class="site-main">
  {{! HERO SECTION: Cover Image | Description }}
  <section class="hero-section">
    {{#if @site.cover_image}}
      <div class="hero-image-container">
        <img
          class="hero-image"
          src="{{@site.cover_image}}"
          alt="{{@site.title}}"
          loading="lazy"
        />
      </div>
    {{/if}}

    <div class="hero-content">
      {{#if @site.description}}
        <h1 class="hero-description">{{@site.description}}</h1>
      {{/if}}
    </div>
  </section>

  <div class="inner-container">

    <section
      class="work-section"
      style="margin: 0 auto 4rem auto; max-width: 1200px;"
    >
      {{#get "posts" filter="tag:hash-home-posts" limit="all"}}
        <div style="display: flex; flex-direction: column; gap: 2rem;">
        {{#foreach posts}}
          <article
            class="work-post"
            style="display: flex; gap: 4rem; align-items: center; padding: 3rem; flex-wrap: wrap; {{#if @even}}background-color: #e5ead3; flex-direction: row; text-align: right;{{else}}background-color: transparent; flex-direction: row-reverse; text-align: left;{{/if}}"
          >
            {{#if feature_image}}
              <div style="flex: 1; min-width: 300px;">
                <img
                  src="{{img_url feature_image size="l"}}"
                  alt="{{title}}"
                  style="width: 100%; height: auto; object-fit: cover; border: 2px solid #2b6142;"
                  loading="lazy"
                />
              </div>
            {{/if}}
            <div class="work-content" style="flex: 1; min-width: 300px; display: flex; flex-direction: column; justify-content: center; {{#if @even}}align-items: flex-end;{{else}}align-items: flex-start;{{/if}}">
              <h2 style="margin-top: 0; margin-bottom: 1rem; font-size: 2rem; color: #111;">{{title}}</h2>
              
              <div style="margin: 0 0 1.6rem 0; color: #444; font-size: 1.15rem; line-height: 1.6; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                {{content}}
              </div>
              
              {{#if custom_excerpt}}
                <div style="margin: 0 0 1.5rem 0; font-size: 1.4rem; color: #d63384; font-weight: 700; font-family: Times, serif; font-style: italic;">
                  {{custom_excerpt}}
                </div>
              {{/if}}
              <a href="{{url}}" style="display: inline-block; background-color: #31724a; color: white; padding: 0.6rem 1.5rem; border-radius: 25px; text-decoration: none; font-weight: 800; font-size: 0.9rem; letter-spacing: 0.5px; text-transform: uppercase; box-shadow: 0 4px 6px rgba(0,0,0,0.15);">LEARN MORE</a>
            </div>
          </article>
        {{/foreach}}
        </div>
      {{/get}}
    </section>

    <section class="partners-section" style="margin: 0 auto 4rem auto; max-width: 1200px; text-align: center;">
      <h1 style="margin-bottom: 2rem;">Friends & Collaborators</h1>
      <div class="partners-container" style="display: flex; gap: 2rem; justify-content: center; flex-wrap: wrap;">
        {{#get "posts" filter="tag:hash-partner" limit="all"}}
          {{#foreach posts}}
            {{#if feature_image}}
              <a href="{{#if custom_excerpt}}{{custom_excerpt}}{{else}}{{url}}{{/if}}" title="{{title}}" style="flex: 0 0 auto;">
                <img
                  src="{{img_url feature_image size="s"}}"
                  alt="{{title}}"
                  style="width: auto; height: 110px; object-fit: cover;"
                  loading="lazy"
                />
              </a>
            {{/if}}
          {{/foreach}}
        {{/get}}
      </div>
    </section>

    <section class="partners-section" style="margin: 0 auto 4rem auto; max-width: 1200px; text-align: center;">
      <h1 style="margin-bottom: 2rem;">Tech Partners</h1>
      <div class="partners-container" style="display: flex; gap: 2rem; justify-content: center; flex-wrap: wrap;">
        {{#get "posts" filter="tag:hash-techpartner" limit="all"}}
          {{#foreach posts}}
            {{#if feature_image}}
              <a href="{{#if custom_excerpt}}{{custom_excerpt}}{{else}}{{url}}{{/if}}" title="{{title}}" style="flex: 0 0 auto;">
                <img
                  src="{{img_url feature_image size="s"}}"
                  alt="{{title}}"
                  style="width: 120px; height: 120px; object-fit: cover; border-radius: 50%; box-shadow: 0 2px 8px rgba(0,0,0,0.1);"
                  loading="lazy"
                />
              </a>
            {{/if}}
          {{/foreach}}
        {{/get}}
      </div>
    </section>

    <section class="partners-section" style="margin: 0 auto 4rem auto; max-width: 1200px; text-align: center;">
      <h1 style="margin-bottom: 2rem;">Patrons</h1>
      <div class="partners-container" style="display: flex; gap: 2rem; justify-content: center; flex-wrap: wrap; align-items: center;">
        {{#get "posts" filter="tag:hash-patron" limit="all"}}
          {{#foreach posts}}
            <a href="{{#if custom_excerpt}}{{custom_excerpt}}{{else}}{{url}}{{/if}}" title="{{title}}" style="flex: 0 0 auto; font-size: 1.6rem; color: #333; text-decoration: none;">
              {{#if feature_image}}
                <img
                  src="{{img_url feature_image size="s"}}"
                  alt="{{title}}"
                  style="width: auto; height: 100px; object-fit: contain;"
                  loading="lazy"
                />
              {{else}}
                {{title}}
              {{/if}}
            </a>
          {{/foreach}}
        {{/get}}
      </div>
    </section>

        <section class="partners-section featured-section" style="margin: 0 auto 4rem auto; max-width: 1200px; text-align: center;">
      <h1 style="margin-bottom: 2rem;">As Featured In</h1>
      <div class="partners-container" style="display: flex; gap: 2rem; justify-content: center; flex-wrap: wrap; align-items: center;">
        {{#get "posts" filter="tag:hash-featured" limit="all"}}
          {{#foreach posts}}
            {{#if feature_image}}
              <a href="{{#if custom_excerpt}}{{custom_excerpt}}{{else}}{{url}}{{/if}}" title="{{title}}" target="_blank" rel="noopener noreferrer" style="flex: 0 0 auto; transition: transform 0.2s ease, opacity 0.2s ease;">
                <img
                  src="{{img_url feature_image size="s"}}"
                  alt="{{title}}"
                  style="width: auto; height: 90px; object-fit: contain;"
                  loading="lazy"
                />
              </a>
            {{/if}}
          {{/foreach}}
        {{/get}}
      </div>
    </section>

  </div>
</main>