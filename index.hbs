{{!< default}}

<main id="main-content" class="site-main home-page">
  <section class="hero-section hero-section-home">
    {{#if @site.cover_image}}
      <div class="hero-image-container">
        <div class="hero-image-frame">
          <img
            class="hero-image"
            src="{{@site.cover_image}}"
            alt="{{@site.title}}"
            loading="lazy"
          />
        </div>
      </div>
    {{/if}}

    <div class="hero-content">
      {{#if @site.description}}
        <h1 class="hero-description">{{@site.description}}</h1>
      {{/if}}
    </div>
  </section>

  <div class="inner-container home-inner-container">
    <section class="work-section index-work-section">
      {{#get "posts" filter="tag:hash-home-work-posts" limit="100"}}
        <div class="work-posts-container">
          {{#foreach posts}}
            <article class="work-post {{#if @even}}work-post-even{{else}}work-post-odd{{/if}}">
              {{#if feature_image}}
                <div class="work-post-image">
                  <img
                    src="{{img_url feature_image size="l"}}"
                    alt="{{title}}"
                    loading="lazy"
                  />
                </div>
              {{/if}}
              <div class="work-content">
                <h2 class="work-title">{{title}}</h2>

                <div class="work-excerpt">
                  {{content}}
                </div>

                {{#if custom_excerpt}}
                  <div class="work-custom-excerpt">
                    {{custom_excerpt}}
                  </div>
                {{/if}}
                <a href="{{#if canonical_url}}{{canonical_url}}{{else}}{{url}}{{/if}}" class="btn-learn-more">Learn More</a>
              </div>
            </article>
          {{else}}
            <p class="section-empty-note">Fresh programs are on the way. Please check back soon.</p>
          {{/foreach}}
        </div>
      {{/get}}
    </section>

    {{#get "posts" filter="tag:hash-home-posts" limit="100"}}
      <div class="home-posts-container">
        {{#foreach posts}}
          {{#if custom_excerpt}}
            <section class="hero-section custom-home-hero">
              {{#if feature_image}}
                <div class="custom-posts-content-image-container">
                  <img
                    class="custom-posts-content-image"
                    src="{{img_url feature_image size="l"}}"
                    alt="{{title}}"
                    loading="lazy"
                  />
                </div>
              {{/if}}
              <div class="hero-content">
                <div class="custom-posts-content">{{custom_excerpt}}</div>
              </div>
            </section>
          {{else}}
            <article class="home-post">
              {{#if feature_image}}
                <img src="{{img_url feature_image size="l"}}" alt="{{title}}" loading="lazy" />
              {{/if}}
            </article>
          {{/if}}
        {{/foreach}}
      </div>
    {{/get}}

    <section class="partners-section logo-carousel-section" data-carousel-group>
      <div class="section-head">
        <h2>Friends &amp; Collaborators</h2>
      </div>
      <div class="partners-container logo-carousel-track" id="friends-carousel" tabindex="0" aria-label="Friends and Collaborators logos">
        {{#get "posts" filter="tag:hash-partner" limit="100"}}
          {{#foreach posts}}
            {{#if feature_image}}
              <a href="{{#if custom_excerpt}}{{custom_excerpt}}{{else}}{{url}}{{/if}}" title="{{title}}" class="logo-item logo-item-friends">
                <img
                  src="{{img_url feature_image size="m"}}"
                  alt="{{title}}"
                  class="logo-item-image"
                  loading="lazy"
                />
              </a>
            {{else}}
              <a href="{{#if custom_excerpt}}{{custom_excerpt}}{{else}}{{url}}{{/if}}" title="{{title}}" class="logo-item logo-item-text">{{title}}</a>
            {{/if}}
          {{else}}
            <p class="section-empty-note">Collaborator logos will appear here soon.</p>
          {{/foreach}}
        {{/get}}
      </div>
    </section>

    <section class="partners-section logo-carousel-section" data-carousel-group>
      <div class="section-head">
        <h2>Tech Partners</h2>
      </div>
      <div class="partners-container logo-carousel-track" id="tech-carousel" tabindex="0" aria-label="Tech Partners logos">
        {{#get "posts" filter="tag:hash-techpartner" limit="100"}}
          {{#foreach posts}}
            {{#if feature_image}}
              <a href="{{#if custom_excerpt}}{{custom_excerpt}}{{else}}{{url}}{{/if}}" title="{{title}}" class="logo-item logo-item-tech">
                <img
                  src="{{img_url feature_image size="m"}}"
                  alt="{{title}}"
                  class="logo-item-image"
                  loading="lazy"
                />
              </a>
            {{else}}
              <a href="{{#if custom_excerpt}}{{custom_excerpt}}{{else}}{{url}}{{/if}}" title="{{title}}" class="logo-item logo-item-text">{{title}}</a>
            {{/if}}
          {{else}}
            <p class="section-empty-note">Tech partner logos will appear here soon.</p>
          {{/foreach}}
        {{/get}}
      </div>
    </section>

    <section class="partners-section logo-carousel-section" data-carousel-group>
      <div class="section-head">
        <h2>Patrons</h2>
      </div>
      <div class="partners-container logo-carousel-track" id="patron-carousel" tabindex="0" aria-label="Patrons list">
        {{#get "posts" filter="tag:hash-patron" limit="100"}}
          {{#foreach posts}}
            <a href="{{#if custom_excerpt}}{{custom_excerpt}}{{else}}{{url}}{{/if}}" title="{{title}}" class="logo-item logo-item-patron">
              {{#if feature_image}}
                <img
                  src="{{img_url feature_image size="m"}}"
                  alt="{{title}}"
                  class="logo-item-image"
                  loading="lazy"
                />
              {{else}}
                <span class="patron-text">{{title}}</span>
              {{/if}}
            </a>
          {{else}}
            <p class="section-empty-note">Patron names and logos will appear here soon.</p>
          {{/foreach}}
        {{/get}}
      </div>
    </section>

    <section class="partners-section logo-carousel-section featured-section" data-carousel-group>
      <div class="section-head">
        <h2>As Featured In</h2>
      </div>
      <div class="partners-container logo-carousel-track" id="featured-carousel" tabindex="0" aria-label="As Featured In logos">
        {{#get "posts" filter="tag:hash-featured" limit="100"}}
          {{#foreach posts}}
            {{#if feature_image}}
              <a href="{{#if custom_excerpt}}{{custom_excerpt}}{{else}}{{url}}{{/if}}" title="{{title}}" class="logo-item logo-item-featured" target="_blank" rel="noopener noreferrer">
                <img
                  src="{{img_url feature_image size="m"}}"
                  alt="{{title}}"
                  class="logo-item-image"
                  loading="lazy"
                />
              </a>
            {{/if}}
          {{else}}
            <p class="section-empty-note">Media mentions will appear here soon.</p>
          {{/foreach}}
        {{/get}}
      </div>
    </section>
  </div>
</main>