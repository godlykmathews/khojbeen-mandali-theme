{{!< default}}

<main id="main-content" class="site-main">
  {{! HERO SECTION: Cover Image | Description }}
  <section class="hero-section">
    {{#if @site.cover_image}}
      <div class="hero-image-container">
        <img
          class="hero-image"
          src="{{@site.cover_image}}"
          alt="{{@site.title}}"
          loading="lazy"
        />
      </div>
    {{/if}}

    <div class="hero-content">
      {{#if @site.description}}
        <h1 class="hero-description">{{@site.description}}</h1>
      {{/if}}
    </div>
  </section>

  <div class="inner-container">

    <section
      class="work-section"
      style="margin: 0 auto 4rem auto; max-width: 1200px;"
    >
      <hr style="border: 0; border-top: 1px solid #eee; margin-bottom: 2rem;" />
      {{#get "posts" filter="tag:work" limit="all"}}
        {{#foreach posts}}
          <article
            class="work-post"
            style="display: flex; gap: 1.5rem; align-items: flex-start; margin-bottom: 2rem; flex-wrap: wrap; {{#if @odd}}flex-direction: row-reverse;{{/if}}"
          >
            {{#if feature_image}}
              <a href="{{url}}" style="flex: 0 0 200px; max-width: 100%;">
                <img
                  src="{{img_url feature_image size="m"}}"
                  alt="{{title}}"
                  style="width: 100%; height: auto; object-fit: cover; border-radius: 50%; aspect-ratio: 1/1;"
                  loading="lazy"
                />
              </a>
            {{/if}}
            <div class="work-content" style="flex: 1; min-width: 250px;">
              <h3 style="margin-top: 0; font-size: 1.5rem;">{{title}}</h3>
              <p style="margin-top: 0.5rem; color: #555;">{{excerpt words="20"}}
                <a href="{{url}}" style="font-weight: bold;">read more...</a></p>
            </div>
          </article>
          <hr
            style="border: 0; border-top: 1px solid #eee; margin-bottom: 2rem;"
          />
        {{/foreach}}
      {{/get}}
    </section>

    <section class="partners-section" style="margin: 0 auto 4rem auto; max-width: 1200px; text-align: center;">
      <h1 style="margin-bottom: 2rem;">Friends & Collaborators</h1>
      <div class="partners-container" style="display: flex; gap: 2rem; justify-content: center; flex-wrap: wrap;">
        {{#get "posts" filter="tag:hash-partner" limit="all"}}
          {{#foreach posts}}
            {{#if feature_image}}
              <a href="{{#if custom_excerpt}}{{custom_excerpt}}{{else}}{{url}}{{/if}}" title="{{title}}" style="flex: 0 0 auto;">
                <img
                  src="{{img_url feature_image size="s"}}"
                  alt="{{title}}"
                  style="width: auto; height: 110px; object-fit: cover;"
                  loading="lazy"
                />
              </a>
            {{/if}}
          {{/foreach}}
        {{/get}}
      </div>
    </section>

    <section class="partners-section" style="margin: 0 auto 4rem auto; max-width: 1200px; text-align: center;">
      <h1 style="margin-bottom: 2rem;">Tech Partners</h1>
      <div class="partners-container" style="display: flex; gap: 2rem; justify-content: center; flex-wrap: wrap;">
        {{#get "posts" filter="tag:hash-techpartner" limit="all"}}
          {{#foreach posts}}
            {{#if feature_image}}
              <a href="{{#if custom_excerpt}}{{custom_excerpt}}{{else}}{{url}}{{/if}}" title="{{title}}" style="flex: 0 0 auto;">
                <img
                  src="{{img_url feature_image size="s"}}"
                  alt="{{title}}"
                  style="width: 120px; height: 120px; object-fit: cover; border-radius: 50%; box-shadow: 0 2px 8px rgba(0,0,0,0.1);"
                  loading="lazy"
                />
              </a>
            {{/if}}
          {{/foreach}}
        {{/get}}
      </div>
    </section>

    <section class="partners-section" style="margin: 0 auto 4rem auto; max-width: 1200px; text-align: center;">
      <h1 style="margin-bottom: 2rem;">Patrons</h1>
      <div class="partners-container" style="display: flex; gap: 2rem; justify-content: center; flex-wrap: wrap; align-items: center;">
        {{#get "posts" filter="tag:hash-patron" limit="all"}}
          {{#foreach posts}}
            <a href="{{#if custom_excerpt}}{{custom_excerpt}}{{else}}{{url}}{{/if}}" title="{{title}}" style="flex: 0 0 auto; font-size: 1.6rem; color: #333; text-decoration: none;">
              {{#if feature_image}}
                <img
                  src="{{img_url feature_image size="s"}}"
                  alt="{{title}}"
                  style="width: auto; height: 100px; object-fit: contain;"
                  loading="lazy"
                />
              {{else}}
                {{title}}
              {{/if}}
            </a>
          {{/foreach}}
        {{/get}}
      </div>
    </section>

  </div>
</main>