{{!< default}}

<main id="main-content" class="site-main">
  {{! HERO SECTION: Cover Image | Description }}
  <section class="hero-section">
    {{#if @site.cover_image}}
      <div class="hero-image-container">
        <img
          class="hero-image"
          src="{{@site.cover_image}}"
          alt="{{@site.title}}"
          loading="lazy"
        />
      </div>
    {{/if}}

    <div class="hero-content">
      {{#if @site.description}}
        <h1 class="hero-description">{{@site.description}}</h1>
      {{/if}}
    </div>
  </section>

  <div class="inner-container">

    <section class="work-section index-work-section">
      {{#get "posts" filter="tag:hash-home-posts" limit="100"}}
        <div class="work-posts-container">
        {{#foreach posts}}
          <article class="work-post {{#if @even}}work-post-even{{else}}work-post-odd{{/if}}">
            {{#if feature_image}}
              <div class="work-post-image">
                <img
                  src="{{img_url feature_image size="l"}}"
                  alt="{{title}}"
                  loading="lazy"
                />
              </div>
            {{/if}}
            <div class="work-content">
              <h2 class="work-title">{{title}}</h2>
              
              <div class="work-excerpt">
                {{content}}
              </div>
              
              {{#if custom_excerpt}}
                <div class="work-custom-excerpt">
                  {{custom_excerpt}}
                </div>
              {{/if}}
              <a href="{{#if canonical_url}}{{canonical_url}}{{else}}{{url}}{{/if}}" class="btn-learn-more">LEARN MORE</a>
            </div>
          </article>
        {{/foreach}}
        </div>
      {{/get}}
    </section>

    <section class="partners-section" style="margin: 0 auto 4rem auto; max-width: 1200px; text-align: center;">
      <h1 style="margin-bottom: 2rem;">Friends & Collaborators</h1>
      <div class="partners-container" style="display: flex; gap: 2rem; justify-content: center; flex-wrap: wrap;">
        {{#get "posts" filter="tag:hash-partner" limit="100"}}
          {{#foreach posts}}
            {{#if feature_image}}
              <a href="{{#if custom_excerpt}}{{custom_excerpt}}{{else}}{{url}}{{/if}}" title="{{title}}" style="flex: 0 0 auto;">
                <img
                  src="{{img_url feature_image size="s"}}"
                  alt="{{title}}"
                  style="width: auto; height: 110px; object-fit: cover;"
                  loading="lazy"
                />
              </a>
            {{/if}}
          {{/foreach}}
        {{/get}}
      </div>
    </section>

    <section class="partners-section" style="margin: 0 auto 4rem auto; max-width: 1200px; text-align: center;">
      <h1 style="margin-bottom: 2rem;">Tech Partners</h1>
      <div class="partners-container" style="display: flex; gap: 2rem; justify-content: center; flex-wrap: wrap;">
        {{#get "posts" filter="tag:hash-techpartner" limit="100"}}
          {{#foreach posts}}
            {{#if feature_image}}
              <a href="{{#if custom_excerpt}}{{custom_excerpt}}{{else}}{{url}}{{/if}}" title="{{title}}" style="flex: 0 0 auto;">
                <img
                  src="{{img_url feature_image size="s"}}"
                  alt="{{title}}"
                  style="width: 120px; height: 120px; object-fit: cover; border-radius: 50%; box-shadow: 0 2px 8px rgba(0,0,0,0.1);"
                  loading="lazy"
                />
              </a>
            {{/if}}
          {{/foreach}}
        {{/get}}
      </div>
    </section>

    <section class="partners-section" style="margin: 0 auto 4rem auto; max-width: 1200px; text-align: center;">
      <h1 style="margin-bottom: 2rem;">Patrons</h1>
      <div class="partners-container" style="display: flex; gap: 2rem; justify-content: center; flex-wrap: wrap; align-items: center;">
        {{#get "posts" filter="tag:hash-patron" limit="100"}}
          {{#foreach posts}}
            <a href="{{#if custom_excerpt}}{{custom_excerpt}}{{else}}{{url}}{{/if}}" title="{{title}}" style="flex: 0 0 auto; font-size: 1.6rem; color: #333; text-decoration: none;">
              {{#if feature_image}}
                <img
                  src="{{img_url feature_image size="s"}}"
                  alt="{{title}}"
                  style="width: auto; height: 100px; object-fit: contain;"
                  loading="lazy"
                />
              {{else}}
                {{title}}
              {{/if}}
            </a>
          {{/foreach}}
        {{/get}}
      </div>
    </section>

        <section class="partners-section featured-section" style="margin: 0 auto 4rem auto; max-width: 1200px; text-align: center;">
      <h1 style="margin-bottom: 2rem;">As Featured In</h1>
      <div class="partners-container" style="display: flex; gap: 2rem; justify-content: center; flex-wrap: wrap; align-items: center;">
        {{#get "posts" filter="tag:hash-featured" limit="100"}}
          {{#foreach posts}}
            {{#if feature_image}}
              <a href="{{#if custom_excerpt}}{{custom_excerpt}}{{else}}{{url}}{{/if}}" title="{{title}}" target="_blank" rel="noopener noreferrer" style="flex: 0 0 auto; transition: transform 0.2s ease, opacity 0.2s ease;">
                <img
                  src="{{img_url feature_image size="s"}}"
                  alt="{{title}}"
                  style="width: auto; height: 90px; object-fit: contain;"
                  loading="lazy"
                />
              </a>
            {{/if}}
          {{/foreach}}
        {{/get}}
      </div>
    </section>

  </div>
</main>