<!-- Include Tailwind CSS for Ghost code injection -->
<script src="https://cdn.tailwindcss.com"></script>

<footer class="bg-white py-12 text-gray-800 border-t border-gray-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row gap-8 justify-between">

      <!-- Left Side -->
      <div class="flex flex-col space-y-8 md:w-1/2">
        {{#if @custom.illustrations_author}}
        <p class="text-sm text-gray-500">
          Illustrations by <a href="{{@custom.illustrations_link}}" target="_blank" rel="noopener" class="underline hover:text-gray-900">{{@custom.illustrations_author}}</a>
        </p>
        {{/if}}
        
        <div>
          <h2 class="text-4xl font-bold mb-4">Contact Us</h2>
          
          <div class="flex flex-col space-y-2 text-lg">
            {{#if @custom.contact_phone}}
            <a href="tel:{{@custom.contact_phone}}" class="hover:text-blue-600 transition-colors">{{@custom.contact_phone}}{{#if @custom.contact_person}} ({{@custom.contact_person}}){{/if}}</a>
            {{/if}}
            {{#if @custom.contact_email}}
            <a href="mailto:{{@custom.contact_email}}" class="hover:text-blue-600 transition-colors">{{@custom.contact_email}}</a>
            {{/if}}
          </div>
        </div>
      </div>

      <!-- Right Side -->
      <div class="flex flex-col space-y-8 md:w-1/2 md:items-end">
        <div class="md:text-right">
          <h4 class="text-2xl font-semibold mb-4">Connect</h4>
          
          {{navigation type="secondary"}}
        </div>
        
        <p class="text-xs text-gray-500 md:text-right mt-auto pt-4">
          &copy; <span id="current-year"></span> Khojbeen Mandali &bull; All Rights Reserved
        </p>
      </div>

    </div>
  </div>

  <script>
    // Ensure the current year populates correctly
    document.getElementById('current-year').textContent = new Date().getFullYear();
  </script>
</footer>