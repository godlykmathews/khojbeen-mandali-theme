{{!< default}}

{{#post}}
  <main id="main-content" class="site-main donation-page">
    <div class="inner-container donation-inner max-w-6xl mx-auto px-4 sm:px-6">
      <section class="donation-hero">
        <div class="donation-hero-content">
          <p class="donation-kicker">Support Khojbeen Mandali</p>
          <h1 class="donation-title">{{title}}</h1>
          {{#if custom_excerpt}}
            <p class="donation-summary">{{custom_excerpt}}</p>
          {{/if}}
          <a class="donation-cta" href="#donation-options">Donate now</a>
        </div>

        {{#if feature_image}}
          <div class="donation-hero-image-wrap">
            <img
              src="{{img_url feature_image size="l"}}"
              alt="{{title}}"
              class="donation-hero-image"
              loading="lazy"
            />
          </div>
        {{/if}}
      </section>
        {{#if content}}
      <article class="donation-content gh-content">
        {{content}}
      </article>
      {{/if}}

      <section id="donation-options" class="donation-methods">
        <div class="section-head">
          <h2>Ways To Contribute</h2>
        </div>

        <div class="donation-method-grid" role="list">
          {{#get "posts" filter="tag:hash-donation-method" limit="100"}}
            {{#foreach posts}}
              <article class="donation-method-card" role="listitem">
                <h3 class="donation-method-title">{{title}}</h3>
                {{#if custom_excerpt}}
                  <p class="donation-method-meta">{{custom_excerpt}}</p>
                {{/if}}
                <div class="donation-method-body gh-content">
                  {{content}}
                </div>
                {{#if canonical_url}}
                  <a href="{{canonical_url}}" class="donation-method-link" target="_blank" rel="noopener noreferrer" aria-label="Contribute via {{title}}">Contribute</a>
                {{/if}}
              </article>
            {{else}}
              <article class="donation-method-card" role="listitem">
                <h3 class="donation-method-title">Coming Soon</h3>
                <p class="donation-method-meta">Thank you for your interest in supporting us!</p>
                <p class="donation-method-body">We are currently setting up our donation channels. Please check back soon, or contact us directly if you wish to contribute in the meantime.</p>
              </article>
            {{/foreach}}
          {{/get}}
        </div>
      </section>
    </div>
  </main>
{{/post}}
