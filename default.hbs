<!DOCTYPE html>
<html lang="{{@site.locale}}">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{meta_title}}</title>
    
    <link rel="stylesheet" type="text/css" href="{{asset "css/screen.css"}}" />
    
    {{ghost_head}}
</head>
<body class="{{body_class}}">
    <div class="site-wrapper">
        
        <header class="site-header-global">
            <div class="inner-container">
                <a class="site-nav-logo" href="{{@site.url}}">{{@site.title}}</a>
                {{#if @site.navigation}}
                    {{navigation}}
                {{/if}}
            </div>
        </header>

        {{{body}}}

        <footer class="site-footer-global">
            <div class="inner-container">
                <section class="copyright"><a href="{{@site.url}}">{{@site.title}}</a> &copy; {{date format="YYYY"}}</section>
                <nav class="site-footer-nav">
                    <a href="{{@site.url}}">Latest Posts</a>
                    {{#if @site.facebook}}<a href="{{social_url type="facebook" @site.facebook}}" target="_blank" rel="noopener">Facebook</a>{{/if}}
                    {{#if @site.twitter}}<a href="{{social_url type="twitter" @site.twitter}}" target="_blank" rel="noopener">Twitter</a>{{/if}}
                </nav>
            </div>
        </footer>

    </div>

    {{ghost_foot}}
</body>
</html>
